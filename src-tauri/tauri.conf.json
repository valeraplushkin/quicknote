{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "quicknote",
  "version": "0.1.0",
  "identifier": "com.nikita.quicknote",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "capture",
        "title": "QuickNote",
        "width": 480,
        "height": 120,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "resizable": false,
        "center": false
      },
      {
        "label": "notes-list",
        "title": "QuickNote — All Notes",
        "width": 520,
        "height": 440,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "skipTaskbar": true,
        "center": true
      },
      {
        "label": "onboarding",
        "title": "Welcome to QuickNote",
        "width": 600,
        "height": 540,
        "decorations": false,
        "visible": false,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
